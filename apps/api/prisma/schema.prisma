generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

model User {
    id              BigInt     @id @unique @default(autoincrement())
    userCode        String?    @unique
    email           String     @unique
    pswHash         String // argon2
    name            String
    createdAt       DateTime   @default(now())
    updatedAt       DateTime   @updatedAt
    role            Role       @default(CUSTOMER)
    status          UserStatus @default(PENDING_APPROVAL)
    projects        Project[]
    assignedTickets Ticket[]   @relation("assignedTickets")
    reportedTickets Ticket[]   @relation("reportedTickets")
    adminLogs       AdminLog[]
}

model Project {
    id          BigInt    @id @unique @default(autoincrement())
    projectCode String?   @unique
    projectName String
    description String?
    startDate   DateTime
    endDate     DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    company     Company   @relation(fields: [companyId], references: [id])
    users       User[]
    tickets     Ticket[]
    companyId   BigInt
}

model Company {
    id            BigInt    @id @unique @default(autoincrement())
    companyCode   String?   @unique
    companyName   String
    nationality   String
    description   String?
    referralEmail String    @unique
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    projects      Project[]
}

model Ticket {
    id                BigInt         @id @unique @default(autoincrement())
    ticketCode        String         @unique
    ticketName        String
    ticketDescription String?
    startDate         DateTime?
    endDate           DateTime?
    status            Status         @default(ON_QUEUE)
    category          TicketCategory @default(GENERAL)
    priority          Priority       @default(MEDIUM)
    createdAt         DateTime       @default(now())
    updatedAt         DateTime       @updatedAt
    resolvedAt        DateTime?
    project           Project?       @relation(fields: [projectId], references: [id], onDelete: Restrict)
    projectId         BigInt?
    assignee          User?          @relation("assignedTickets", fields: [assigneeId], references: [id])
    assigneeId        BigInt?
    reporter          User?          @relation("reportedTickets", fields: [reporterId], references: [id])
    reporterId        BigInt?
}

model AdminLog {
    id          BigInt   @id @unique @default(autoincrement())
    actorId     BigInt
    action      String // ticket_create, user_approve ecc.
    targetType  String
    targetCode  String?
    targetLabel String?
    details     Json?
    createdAt   DateTime @default(now())
    actor       User     @relation(fields: [actorId], references: [id])

    @@index([createdAt])
    @@index([actorId])
    @@index([targetType])
}

model SystemLog {
    id        BigInt   @id @default(autoincrement())
    level     LogLevel @default(ERROR)
    message   String   @db.Text
    stack     String?  @db.Text
    context   Json?
    createdAt DateTime @default(now())
}

enum LogLevel {
    INFO
    WARN
    ERROR
}

enum Role {
    CUSTOMER
    AGENT
    ADMIN
}

enum TicketCategory {
    GENERAL
    BUG
    FEATURE
    SUPPORT
    MAINTENANCE
}

enum Priority {
    LOW
    MEDIUM
    HIGH
    URGENT
}

enum UserStatus {
    PENDING_APPROVAL
    APPROVED
    REJECTED
    SUSPENDED
}

enum Status {
    ON_HOLD
    ON_APPROVAL
    ON_QUEUE
    FULFILLMENT
    APPROVED
    REJECTED
    DONE
    CANCELLED
}
