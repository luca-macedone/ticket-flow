{
    "name": "@packages/shared",
    "private": true,
    "version": "0.0.0",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "lint": "echo \"(optional) lint shared\"",
        "test": "echo \"(optional) test shared\"",
        "generate:fe": "tsx scripts/extract-fe-rules.ts",
        "generate": "pnpm run generate:fe"
    },
    "dependencies": {
        "zod": "^3.0.0"
    },
    "devDependencies": {
        "tsup": "^8.5.1"
    }
}